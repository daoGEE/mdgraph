{
  "name": "@daogee/mdgraph",
  "version": "1.0.0",
  "description": "Local-first Markdown document graph for AI coding workflows.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daoGEE/mdgraph.git"
  },
  "bugs": {
    "url": "https://github.com/daoGEE/mdgraph/issues"
  },
  "homepage": "https://github.com/daoGEE/mdgraph#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "agent-pack",
    "docs/EN/*.md",
    "docs/ZH/*.md",
    "README.md",
    "README-ZH.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "mdgraph": "dist/bin/mdgraph.js"
  },
  "scripts": {
    "build": "tsc && node scripts/assets.mjs",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "smoke:clean": "node scripts/smoke-clean.mjs",
    "smoke:eval": "node scripts/smoke-eval.mjs",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "task:check": "node scripts/task-tools.mjs check",
    "task:new": "node scripts/task-tools.mjs new",
    "task:public-check": "node scripts/task-tools.mjs public-check",
    "task:smoke": "node scripts/task-tools.mjs smoke",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "markdown",
    "knowledge-graph",
    "document-graph",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "coding-agents",
    "local-first",
    "sqlite",
    "documentation"
  ],
  "author": "daoGEE"
}
